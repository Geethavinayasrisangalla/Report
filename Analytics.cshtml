@model IEnumerable<FarmManagement.Web.Models.ViewModels.YieldAnalyticsViewModels>

@{
    ViewData["Title"] = "Yield Analytics";
}

<h2>Yield Analytics</h2>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">
        No analytics data available.
    </div>
}
else
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Field Name</th>
                <th>Area Size</th>
                <th>Total Yield</th>
                <th>Average Yield</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.FieldName</td>
                    <td>@item.AreaSize</td>
                    <td>@item.TotalYield</td>
                    <td>@item.AverageYield</td>
                </tr>
            }
        </tbody>
    </table>
}
``
